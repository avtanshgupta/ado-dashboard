# Backend server port (frontend dev server proxies /api here)
PORT=4000

# ---- Access ----
# The app is multi-user: each person signs in with their own Azure DevOps token
# and acts with their own permissions. The ONLY login gate is group membership —
# a user may sign in iff they are a member of this Azure DevOps / AAD group
# (checked live via the IdentityPicker). Override the group here; set it EMPTY to
# disable the gate (open to anyone who can authenticate against the org).
ALLOWED_GROUP=mdelinux@microsoft.com
# Hosted deployments have no local `az` CLI — set true so the server skips the
# local-identity fallback and always uses per-user token-paste sign-in.
DISABLE_AZ_FALLBACK=false

# ---- Sessions / cookies ----
# Serve over HTTPS in production and set COOKIE_SECURE=true.
COOKIE_SECURE=false
# COOKIE_NAME=ado_sid
# Where user/session/notification state is written. On a hosted platform
# point this at persistent storage so deploys & restarts don't wipe logins.
# DATA_DIR=/home/data
# Comma-separated extra CORS origins (in addition to localhost). Usually unset.
# ALLOWED_ORIGINS=

# ---- Token encryption at rest ----
# Azure access tokens in the vault are encrypted with AES-256-GCM. Provide a
# 32-byte key as 64 hex chars or base64 to keep the key OUTSIDE the data dir
# (recommended for hosted deployments — e.g. sourced from Key Vault). If unset, a
# per-install keyfile (<DATA_DIR>/.token-key) is generated automatically.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# TOKEN_ENC_KEY=

# ---- Email notifications (optional) ----
# Leave SMTP_HOST empty to disable email; in-app notifications always work.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL_FROM=
